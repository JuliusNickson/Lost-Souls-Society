# Shopify Headless — Storefront API (server-only)
# Find domain in Shopify Admin → Settings → Domains (xxx.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Prefer the Private access token for server functions (never expose to the browser)
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# Optional fallback if you only have the Public access token
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
